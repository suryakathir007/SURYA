#include <stdio.h>
#include <string.h>
#include <ctype.h>
int main() 
{
    char s[1001];
    int counts[10] = {0};
    if (scanf("%s", s) == 1) 
{
        for (int i = 0; s[i] != '\0'; i++)
{
            if (s[i] >= '0' && s[i] <= '9') 
{
counts[s[i] - '0']++;
}
}
}
    for (int i = 0; i < 10; i++)
{
        printf("%d ", counts[i]);
}
    printf("\n");
    return 0;
}
