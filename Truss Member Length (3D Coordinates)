#include <stdio.h>
#include <math.h>

int main() {
    float x1, y1, z1, x2, y2, z2, length;
    printf("Enter Coordinates of Node 1 (x y z): ");
    scanf("%f %f %f", &x1, &y1, &z1);
    printf("Enter Coordinates of Node 2 (x y z): ");
    scanf("%f %f %f", &x2, &y2, &z2);

    length = sqrt(pow(x2-x1, 2) + pow(y2-y1, 2) + pow(z2-z1, 2));

    printf("Length of Truss Member: %.3f units\n", length);
    return 0;
}
