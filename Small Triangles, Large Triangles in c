#include <stdio.h>
#include <stdlib.h>
#include <math.h>

struct triangle
{
	int a;
	int b;
	int c;
};

typedef struct triangle triangle;
void sort_by_area(triangle* tr, int n) 
{
    double *square_areas = malloc(n * sizeof(double));
    for (int i = 0; i < n; i++) 
    {
        float a = tr[i].a;
        float b = tr[i].b;
        float c = tr[i].c;
        float p = (a + b + c) / 2.0;
        square_areas[i] = p * (p - a) * (p - b) * (p - c);
    }
    for (int i = 0; i < n; i++) 
    {
        for (int j = 0; j < n - i - 1; j++) 
        {
            if (square_areas[j] > square_areas[j + 1]) 
            {
                double temp_area = square_areas[j];
                square_areas[j] = square_areas[j + 1];
                square_areas[j + 1] = temp_area;
                triangle temp_tr = tr[j];
                tr[j] = tr[j + 1];
                tr[j + 1] = temp_tr;
            }
        }
    }
    free(square_areas);
}


int main()
{
	int n;
	scanf("%d", &n);
	triangle *tr = malloc(n * sizeof(triangle));
	for (int i = 0; i < n; i++) {
		scanf("%d%d%d", &tr[i].a, &tr[i].b, &tr[i].c);
	}
	sort_by_area(tr, n);
	for (int i = 0; i < n; i++) {
		printf("%d %d %d\n", tr[i].a, tr[i].b, tr[i].c);
	}
	return 0;
}
