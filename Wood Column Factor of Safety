#include <stdio.h>

int main() {
    float load, area, ultStress, fos, actStress;
    printf("Enter applied axial load (kN): ");
    scanf("%f", &load);
    printf("Enter Column Area (mm^2): ");
    scanf("%f", &area);
    printf("Enter Ultimate Stress of Wood (MPa): ");
    scanf("%f", &ultStress);

    actStress = (load * 1000.0) / area;
    fos = ultStress / actStress;

    printf("\nActual Stress: %.2f MPa\n", actStress);
    printf("Factor of Safety: %.2f\n", fos);
    
    if(fos >= 3.0) printf("Status: SAFE for Timber Design\n");
    else printf("Status: UNSAFE (Increase section size)\n");

    return 0;
}
