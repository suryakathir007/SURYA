#include <stdio.h>

int main() {
    int n;
    printf("Enter number of vertices: ");
    scanf("%d", &n);
    float x[n], y[n], area = 0;

    for(int i = 0; i < n; i++) {
        printf("Enter coordinates for point %d (x y): ", i + 1);
        scanf("%f %f", &x[i], &y[i]);
    }

    int j = n - 1;
    for (int i = 0; i < n; i++) {
        area += (x[j] + x[i]) * (y[j] - y[i]);
        j = i;
    }

    printf("Total Area of Plot: %.2f sq. units\n", fabs(area / 2.0));
    return 0;
}
